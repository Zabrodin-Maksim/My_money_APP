<UserControl x:Class="My_money.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44"
                        Height="44"
                        Background="{StaticResource AccentButtonBrush}"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <fa:IconImage Icon="Gear"
                                  Width="18"
                                  Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Border>

                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="Settings" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Manage your profile details and password rules for the signed-in account." Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource ContentCardStyle}">
                <StackPanel>
                    <TextBlock Text="Profile" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="Update the display name shown in the household workspace." Style="{StaticResource PageSubtitleTextStyle}" Margin="0,6,0,0" />

                    <TextBlock Text="Display name" Style="{StaticResource FieldLabelTextStyle}" Margin="0,22,0,0" />
                    <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />

                    <TextBlock Text="Email" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                    <TextBox Text="{Binding Email}" IsReadOnly="True" Style="{StaticResource AppTextBoxStyle}" />

                    <Button Command="{Binding SaveProfileCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="180" Margin="0,24,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:IconImage Icon="FloppyDisk" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Save profile" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource MutedCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Password status" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="{Binding PasswordHint}" Style="{StaticResource PageSubtitleTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Password" Style="{StaticResource SectionTitleTextStyle}" />

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanChangeOwnPassword}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="Current password" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <PasswordBox PasswordChanged="CurrentPasswordBox_OnPasswordChanged"
                                         Style="{StaticResource AppPasswordBoxStyle}" />

                            <TextBlock Text="New password" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <PasswordBox PasswordChanged="NewPasswordBox_OnPasswordChanged"
                                         Style="{StaticResource AppPasswordBoxStyle}" />

                            <TextBlock Text="Confirm new password" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <PasswordBox PasswordChanged="ConfirmPasswordBox_OnPasswordChanged"
                                         Style="{StaticResource AppPasswordBoxStyle}" />

                            <Button Command="{Binding ChangePasswordCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="210" Margin="0,24,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:IconImage Icon="Key" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Change password" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="Child accounts cannot change their own password. An admin must update it from the household members screen."
                                   TextWrapping="Wrap"
                                   Margin="0,18,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource PageSubtitleTextStyle}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CanChangeOwnPassword}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
