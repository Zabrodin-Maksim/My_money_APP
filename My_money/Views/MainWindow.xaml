<Window x:Class="My_money.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
        xmlns:vm="clr-namespace:My_money.ViewModel"
        xmlns:views="clr-namespace:My_money.Views"
        mc:Ignorable="d"
        Title="My Money"
        Height="860"
        Width="1440"
        MinHeight="760"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:RegistrationViewModel}">
            <views:RegistrationView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AddViewModel}">
            <views:AddView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:MoneyBoxViewModel}">
            <views:MoneyBoxView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:PlanViewModel}">
            <views:PlanView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:HouseholdMembersViewModel}">
            <views:HouseholdMembersView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
    </Window.Resources>

    <Grid Background="Transparent" MouseLeftButtonDown="Grid_MouseLeftButtonDown">
        <Border Margin="0"
                Background="{StaticResource AppChromeGradientBrush}"
                BorderBrush="{StaticResource BorderBrushStrong}"
                BorderThickness="1"
                CornerRadius="34">
            <Grid Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SidebarPanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <Border Width="68"
                                    Height="68"
                                    Background="{StaticResource AccentButtonBrush}"
                                    CornerRadius="22"
                                    HorizontalAlignment="Left">
                                <fa:IconImage Icon="Wallet"
                                              Width="30"
                                              Height="30"
                                              Foreground="{StaticResource TextPrimaryBrush}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                            </Border>

                            <TextBlock Text="My Money"
                                       Style="{StaticResource PageTitleTextStyle}"
                                       Margin="0,18,0,0" />

                            <Border Style="{StaticResource MutedCardStyle}"
                                    Padding="14"
                                    Margin="0,18,0,0">
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentUserName}"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="{Binding CurrentRole, StringFormat=Role: {0}}"
                                               Style="{StaticResource PageSubtitleTextStyle}"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding CurrentHouseholdName, StringFormat=Household: {0}}"
                                               Style="{StaticResource PageSubtitleTextStyle}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding SessionSummary}"
                                               Style="{StaticResource PageSubtitleTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,28,0,0"
                                    Visibility="{Binding AuthenticatedVisibility}">
                            <Button Command="{Binding NavigateToDashboard}"
                                    Style="{StaticResource NavButtonStyle}"
                                    IsEnabled="{Binding CanUseFinanceWorkspace}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ChartPie" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Dashboard" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToMoneyBox}"
                                    Style="{StaticResource NavButtonStyle}"
                                    IsEnabled="{Binding CanUseFinanceWorkspace}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="PiggyBank" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Savings Goals" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToPlan}"
                                    Style="{StaticResource NavButtonStyle}"
                                    IsEnabled="{Binding CanUseFinanceWorkspace}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ListCheck" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Budget Categories" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToHistory}"
                                    Style="{StaticResource NavButtonStyle}"
                                    IsEnabled="{Binding CanUseFinanceWorkspace}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="ClockRotateLeft" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="History" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToMembers}"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding MembersVisibility}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Users" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Members" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToSettings}"
                                    Style="{StaticResource NavButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <fa:IconImage Icon="Gear" Width="18" Height="18" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Settings" Margin="14,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2"
                                Style="{StaticResource MutedCardStyle}"
                                Padding="16"
                                Margin="0,16,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Workspace controls" Margin="0,0,0,10"
                                           Style="{StaticResource SectionTitleTextStyle}" />

                                <StackPanel Grid.Row="2" Orientation="Horizontal">
                                    <Button Command="{Binding MinimizeWindowCommand}" Style="{StaticResource IconButtonStyle}">
                                        <fa:IconImage Icon="WindowMinimize" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Button>

                                    <Button Command="{Binding LogoutCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Margin="10,0,0,0"
                                            Visibility="{Binding AuthenticatedVisibility}">
                                        <fa:IconImage Icon="ArrowRightFromBracket" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Button>

                                    <Button Command="{Binding ExitCommand}" Style="{StaticResource IconButtonStyle}" Margin="10,0,0,0">
                                        <fa:IconImage Icon="Xmark" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Margin="4,0,4,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="Multi-user finance workspace"
                                       Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Authentication, household management, private finances, and shared planning in one application shell."
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="{StaticResource ContentSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrushStrong}"
                            BorderThickness="1"
                            CornerRadius="30"
                            Padding="12">
                        <ContentControl Content="{Binding CurrentView}" />
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
