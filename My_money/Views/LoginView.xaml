<UserControl x:Class="My_money.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*" />
            <ColumnDefinition Width="0.95*" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource ContentCardStyle}" Padding="28">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="46"
                            Height="46"
                            Background="{StaticResource AccentButtonBrush}"
                            CornerRadius="14">
                        <fa:IconImage Icon="RightToBracket"
                                      Width="18"
                                      Height="18"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Margin="14,0,0,0">
                        <TextBlock Text="Login" Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource PageSubtitleTextStyle}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Margin="0,28,0,0">
                    <TextBlock Text="Email" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />

                    <TextBlock Text="Password" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                    <PasswordBox PasswordChanged="PasswordBox_OnPasswordChanged"
                                 Style="{StaticResource AppPasswordBoxStyle}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,24,0,24" HorizontalAlignment="Center">
                    <Button Command="{Binding LoginCommand}" Style="{StaticResource PrimaryButtonStyle}" Width="170">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:IconImage Icon="RightToBracket" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Sign in" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding OpenRegistrationCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="220" Margin="16,0,0,0">
                        <TextBlock Text="Create first household" />
                    </Button>
                </StackPanel>

                <Button Command="{Binding ForgotPasswordCommand}" Style="{StaticResource SecondaryButtonStyle}" Width="180" HorizontalAlignment="Center">
                    <TextBlock Text="Forgot password" />
                </Button>
                
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource MutedCardStyle}" Margin="20,0,0,0">
            <StackPanel>
                <TextBlock Text="Household access model" Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock Text="Admins manage members and the shared budget. Partners work with shared and private finances. Child accounts contribute shared records and stay read-only in planning."
                           Style="{StaticResource PageSubtitleTextStyle}"
                           TextWrapping="Wrap"
                           Margin="0,10,0,0" />

                <Border Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="First login" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Accounts created by an admin arrive with a temporary password and are redirected to settings for a required password change."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Forgot password?" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Enter your email on the left and request a temporary password. After sign-in, the app will force you to set a new one."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
