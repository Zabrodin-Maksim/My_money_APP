<UserControl x:Class="My_money.Views.HouseholdMembersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="44"
                            Height="44"
                            Background="{StaticResource AccentButtonBrush}"
                            CornerRadius="14"
                            VerticalAlignment="Center">
                        <fa:IconImage Icon="Users"
                                      Width="18"
                                      Height="18"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Margin="14,0,0,0">
                        <TextBlock Text="Household Members" Style="{StaticResource PageTitleTextStyle}" />
                        <TextBlock Text="Invite new members, edit roles and permissions, issue temporary passwords, and manage child passwords from one place."
                                   Style="{StaticResource PageSubtitleTextStyle}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*" />
                    <ColumnDefinition Width="0.85*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Border Style="{StaticResource ContentCardStyle}" Padding="0" VerticalAlignment="Top">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="22,22,22,14">
                                <StackPanel>
                                    <TextBlock Text="Current members" Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Text="Only admins can edit display names, roles, and rights directly in the table, then save the selected member."
                                               Style="{StaticResource PageSubtitleTextStyle}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      ItemsSource="{Binding Members}"
                                      SelectedItem="{Binding SelectedMember, Mode=TwoWay}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserSortColumns="False"
                                      ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}"
                                      RowStyle="{StaticResource AppDataGridRowStyle}"
                                      CellStyle="{StaticResource AppDataGridCellStyle}"
                                      Style="{StaticResource AppDataGridStyle}"
                                      Height="430"
                                      Margin="0,0,6,6">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name"
                                                        Binding="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="180"
                                                        EditingElementStyle="{StaticResource AppDataGridEditingTextStyle}"
                                                        ElementStyle="{StaticResource AppDataGridTextStyle}" />
                                    <DataGridTextColumn Header="Email"
                                                        Binding="{Binding EmailDisplay}"
                                                        IsReadOnly="True"
                                                        Width="190"
                                                        ElementStyle="{StaticResource AppDataGridTextStyle}" />
                                    <DataGridTemplateColumn Header="Role" Width="120">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Role}" Style="{StaticResource AppDataGridTextStyle}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.MemberRoleNames, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          SelectedItem="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource AppComboBoxStyle}" />
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Score"
                                                        Binding="{Binding FinancialHealthScore}"
                                                        IsReadOnly="True"
                                                        Width="75"
                                                        ElementStyle="{StaticResource AppDataGridTextStyle}" />
                                    <DataGridCheckBoxColumn Header="Budget Manage"
                                                            Binding="{Binding CanManageBudgetEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="95">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                        <DataGridCheckBoxColumn.EditingElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridCheckBoxColumn.EditingElementStyle>
                                    </DataGridCheckBoxColumn>
                                    <DataGridCheckBoxColumn Header="Members Manage"
                                                            Binding="{Binding CanManageMembersEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Width="95">
                                        <DataGridCheckBoxColumn.ElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridCheckBoxColumn.ElementStyle>
                                        <DataGridCheckBoxColumn.EditingElementStyle>
                                            <Style TargetType="CheckBox">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridCheckBoxColumn.EditingElementStyle>
                                    </DataGridCheckBoxColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="Score race" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding MemberScoreInsight}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Margin="0,6,0,16"
                                       TextWrapping="Wrap" />

                            <lvc:CartesianChart Series="{Binding MemberScoreSeries}"
                                                XAxes="{Binding MemberScoreXAxes}"
                                                YAxes="{Binding MemberScoreYAxes}"
                                                Background="Transparent"
                                                TooltipPosition="Hidden"
                                                LegendPosition="Hidden"
                                                Height="320" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Grid Grid.Column="1" Margin="20,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ContentCardStyle}" Visibility="{Binding AdminVisibility}">
                        <StackPanel>
                            <TextBlock Text="Invite member" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Only admins can add partners, other admins, or child accounts." Style="{StaticResource PageSubtitleTextStyle}" Margin="0,6,0,0" />

                            <TextBlock Text="Display name" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <TextBox Text="{Binding NewMemberName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />

                            <StackPanel Margin="0,18,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewMemberUsesEmail}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Email" Style="{StaticResource FieldLabelTextStyle}" />
                                <TextBox Text="{Binding NewMemberEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                            </StackPanel>

                            <TextBlock Text="Role" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <ComboBox ItemsSource="{Binding RoleOptions}"
                                      SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                                      Style="{StaticResource AppComboBoxStyle}" />

                            <StackPanel Margin="0,18,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewMemberNeedsPassword}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>

                                <TextBlock Text="Initial child password" Style="{StaticResource FieldLabelTextStyle}" />
                                <PasswordBox PasswordChanged="ChildInitialPasswordBox_OnPasswordChanged"
                                             Style="{StaticResource AppPasswordBoxStyle}" />
                            </StackPanel>

                            <Button Command="{Binding AddMemberCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,22,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <fa:IconImage Icon="UserPlus" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Add member" Margin="10,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource MutedCardStyle}" Margin="0,18,0,0" Visibility="{Binding AdminVisibility}">
                        <StackPanel>
                            <TextBlock Text="Edit selected member" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Choose a row on the left, make changes in the table, then save them here." Style="{StaticResource PageSubtitleTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            <Button Command="{Binding SaveSelectedMemberCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,18,0,0">
                                <TextBlock Text="Save selected member" />
                            </Button>
                            <Button Command="{Binding DeleteSelectedMemberCommand}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Margin="0,12,0,0">
                                <TextBlock Text="Delete selected member" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource MutedCardStyle}" Margin="0,18,0,0" Visibility="{Binding AdminVisibility}">
                        <StackPanel>
                            <TextBlock Text="Adult account reset" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Select an adult member and send a new temporary password to their email." Style="{StaticResource PageSubtitleTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            <Button Command="{Binding SendTemporaryPasswordCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,18,0,0">
                                <TextBlock Text="Send temporary password" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0" Visibility="{Binding AdminVisibility}">
                        <StackPanel>
                            <TextBlock Text="Child password" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Select child and set password." Style="{StaticResource PageSubtitleTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />

                            <TextBlock Text="New password for selected child" Style="{StaticResource FieldLabelTextStyle}" Margin="0,18,0,0" />
                            <PasswordBox PasswordChanged="NewChildPasswordBox_OnPasswordChanged"
                                         Style="{StaticResource AppPasswordBoxStyle}" />

                            <Button Command="{Binding UpdateChildPasswordCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,22,0,0">
                                <TextBlock Text="Update child password" />
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
