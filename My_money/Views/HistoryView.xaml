<UserControl x:Class="My_money.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:glob="clr-namespace:System.Globalization;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44"
                        Height="44"
                        Background="{StaticResource AccentButtonBrush}"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <fa:IconImage Icon="ClockRotateLeft"
                                  Width="18"
                                  Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Border>

                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="History" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Browse past records, change the sort order, and remove entries you no longer need."
                               Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="0.78*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource ContentCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="22,22,22,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Record timeline" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Select an item to delete it, or simply scan recent activity by date or amount."
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <ListView Grid.Row="1"
                              SelectedItem="{Binding SelectedItem}"
                              ItemsSource="{Binding Records}"
                              Style="{StaticResource AppListViewStyle}"
                              ItemContainerStyle="{StaticResource AppListViewItemStyle}"
                              Margin="0,0,6,6">
                        <ListView.View>
                            <GridView ColumnHeaderContainerStyle="{StaticResource AppGridViewHeaderStyle}">
                                <GridViewColumn Header="Date" DisplayMemberBinding="{Binding DateTimeOccurred, StringFormat={}{0:dd.MM.yyyy}}" Width="150" />
                                <GridViewColumn Header="Category" DisplayMemberBinding="{Binding CategoryName}" Width="180" />
                                <GridViewColumn Header="Amount" DisplayMemberBinding="{Binding Cost, StringFormat={}{0:c1}, ConverterCulture={x:Static glob:CultureInfo.CurrentCulture}}" Width="150" />
                                <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="420" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ContentCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Sort mode" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Switch between a date-first and amount-first view."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,14" />

                        <Slider Style="{StaticResource AppSliderStyle}"
                                Maximum="1"
                                Value="{Binding SelectedSort, Mode=TwoWay}" />

                        <Grid Margin="2,8,2,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Date" Style="{StaticResource PageSubtitleTextStyle}" HorizontalAlignment="Left" />
                            <TextBlock Grid.Column="1" Text="Amount" Style="{StaticResource PageSubtitleTextStyle}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource MutedCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Delete selection" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Choose an entry from the table and then remove it from history."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,16" />
                        <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:IconImage Icon="TrashCan" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Delete record" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource ContentCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="Tip" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="When you sort by amount, the most expensive records rise to the top, which makes anomalies easier to spot."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
