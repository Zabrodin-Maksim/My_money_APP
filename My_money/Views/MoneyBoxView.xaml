<UserControl x:Class="My_money.Views.MoneyBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:glob="clr-namespace:System.Globalization;assembly=mscorlib"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44"
                        Height="44"
                        Background="{StaticResource AccentButtonBrush}"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <fa:IconImage Icon="PiggyBank"
                                  Width="28"
                                  Height="28"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Border>

                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="Moneybox" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Track shared or private savings goals and see how much savings is still free to assign."
                               Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" DockPanel.Dock="Right" Height="60" Width="60" Background="#22FFFFFF" CornerRadius="14" Panel.ZIndex="1" VerticalAlignment="Center" Margin="378,0,562,0">
            <fa:IconImage Icon="Wallet" Width="40" Height="40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Grid Grid.Row="1" Margin="0,22,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource MetricCardStyle}" Background="{StaticResource MetricTealBrush}">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding SavingsCaption}" Style="{StaticResource MetricCaptionTextStyle}" Foreground="#F2FFFC" />
                    </DockPanel>

                    <TextBlock Text="{Binding TotalSavings, StringFormat={}{0:c0}, ConverterCulture={x:Static glob:CultureInfo.CurrentCulture}}"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="White"
                               Margin="0,18,0,0" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" DockPanel.Dock="Right" Width="60" Height="60" Background="#22FFFFFF" CornerRadius="14" Panel.ZIndex="1" VerticalAlignment="Center" Margin="376,0,64,0" >
                <fa:IconImage Icon="Coins" Width="40" Height="40" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border Grid.Column="1" Style="{StaticResource MetricCardStyle}" Background="{StaticResource MetricBlueBrush}" Margin="18,0,0,0">
                <StackPanel>
                    <DockPanel>
                        <TextBlock Text="{Binding AvailableCaption}" Style="{StaticResource MetricCaptionTextStyle}" Foreground="#EEF2FF" />
                    </DockPanel>

                    <TextBlock Text="{Binding NotUsedMoney, StringFormat={}{0:c0}, ConverterCulture={x:Static glob:CultureInfo.CurrentCulture}}"
                               Style="{StaticResource MetricValueTextStyle}"
                               Foreground="White"
                               Margin="0,18,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource ContentCardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="22,22,22,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Savings goals" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="{Binding ContextDescription}"
                                       Style="{StaticResource PageSubtitleTextStyle}"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              SelectedItem="{Binding SelectedItem}"
                              ItemsSource="{Binding SavingsGoals}"
                              AutoGenerateColumns="False"
                              IsReadOnly="{Binding IsReadOnlyGoals}"
                              Style="{StaticResource AppDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource AppDataGridColumnHeaderStyle}"
                              RowStyle="{StaticResource AppDataGridRowStyle}"
                              CellStyle="{StaticResource AppDataGridCellStyle}"
                              Margin="0,0,6,6">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="RowEditEnding">
                                <i:InvokeCommandAction Command="{Binding UpdateCommand}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Goal name"
                                                Binding="{Binding GoalName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                EditingElementStyle="{StaticResource AppDataGridEditingTextStyle}"
                                                ElementStyle="{StaticResource AppDataGridTextStyle}"
                                                Width="*" />
                            <DataGridTextColumn Header="I have"
                                                Binding="{Binding Have, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ConverterCulture={x:Static glob:CultureInfo.CurrentCulture}, StringFormat=\{0:c0\}}"
                                                EditingElementStyle="{StaticResource AppDataGridEditingTextStyle}"
                                                ElementStyle="{StaticResource AppDataGridTextStyle}"
                                                Width="170" />
                            <DataGridTextColumn Header="Need"
                                                Binding="{Binding Need, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, ConverterCulture={x:Static glob:CultureInfo.CurrentCulture}, StringFormat=\{0:c0\}}"
                                                EditingElementStyle="{StaticResource AppDataGridEditingTextStyle}"
                                                ElementStyle="{StaticResource AppDataGridTextStyle}"
                                                Width="170" />
                            <DataGridTextColumn Header="Progress"
                                                Binding="{Binding Percent, StringFormat={}{0:F1}%}"
                                                ElementStyle="{StaticResource AppDataGridTextStyle}"
                                                Width="140"
                                                IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="20,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ContentCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Context" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Choose whether you want to inspect household, personal, or your own shared goals."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,14" />
                        <ComboBox ItemsSource="{Binding AvailableContexts}"
                                  SelectedItem="{Binding SelectedContext, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  Style="{StaticResource AppComboBoxStyle}"
                                  Margin="0,0,0,16" />

                        <TextBlock Text="Manage goals" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Adults can create, update, and delete goals. Child accounts stay view-only."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,6,0,16" />

                        <Button Command="{Binding AddCommand}" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="{Binding CanManageGoals}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:IconImage Icon="Plus" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Add goal" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding DeleteCommand}" Style="{StaticResource DangerButtonStyle}" Margin="0,12,0,0" IsEnabled="{Binding CanManageGoals}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <fa:IconImage Icon="TrashCan" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Delete goal" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource MutedCardStyle}" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock Text="How this works" Style="{StaticResource SectionTitleTextStyle}" />
                        <TextBlock Text="Available savings is calculated as total savings minus the money already allocated across visible goals.&#x0a;Click a cell to edit the value directly."
                                   Style="{StaticResource PageSubtitleTextStyle}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
