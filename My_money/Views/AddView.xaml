<UserControl x:Class="My_money.Views.AddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="1024">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Border Width="44"
                        Height="44"
                        Background="{StaticResource AccentButtonBrush}"
                        CornerRadius="14"
                        VerticalAlignment="Center">
                    <fa:IconImage Icon="CirclePlus"
                                  Width="18"
                                  Height="18"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
                </Border>

                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="Add entry" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Create a new household or personal record using the new multi-user finance model."
                               Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource ContentCardStyle}" Margin="0,22,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="Entry setup" Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Text="Pick a scope, choose whether this is an expense or income, and set the target when income should change savings or balance."
                               Style="{StaticResource PageSubtitleTextStyle}"
                               Margin="0,6,0,0" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*" />
                        <ColumnDefinition Width="1.1*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.ColumnSpan="2" Style="{StaticResource MutedCardStyle}" Padding="18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Scope" Style="{StaticResource SectionTitleTextStyle}" FontSize="15" />
                                <TextBlock Text="Shared records affect household finances. Personal records stay private to the signed-in user."
                                           Style="{StaticResource PageSubtitleTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <ComboBox ItemsSource="{Binding ScopeOptions}"
                                          SelectedItem="{Binding SelectedScope, Mode=TwoWay}"
                                          Style="{StaticResource AppComboBoxStyle}"
                                          Margin="0,14,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="18,0,0,0">
                                <TextBlock Text="Record type" Style="{StaticResource SectionTitleTextStyle}" FontSize="15" />
                                <TextBlock Text="Expenses reduce money. Income records add money and can target either balance or savings."
                                           Style="{StaticResource PageSubtitleTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <ComboBox ItemsSource="{Binding RecordTypeOptions}"
                                          SelectedItem="{Binding SelectedRecordType, Mode=TwoWay}"
                                          Style="{StaticResource AppComboBoxStyle}"
                                          Margin="0,14,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Row="1" Margin="0,22,18,0">
                        <TextBlock Text="Amount" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Text="{Binding AmountTextProperty, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="18,22,0,0">
                        <TextBlock Text="Category" Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                  DisplayMemberPath="Name"
                                  Style="{StaticResource AppComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="0,18,18,0">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelTextStyle}" />
                        <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                    Style="{StaticResource AppDatePickerStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="18,18,0,0" Visibility="{Binding IncomeTargetVisibility}">
                        <TextBlock Text="Income target" Style="{StaticResource FieldLabelTextStyle}" />
                        <ComboBox ItemsSource="{Binding IncomeTargetOptions}"
                                  SelectedItem="{Binding SelectedIncomeTarget, Mode=TwoWay}"
                                  Style="{StaticResource AppComboBoxStyle}" />
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="0,18,0,0">
                        <TextBlock Text="Description" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Text="{Binding DescriptionProperty, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 AcceptsReturn="True"
                                 MaxHeight="105"
                                 VerticalContentAlignment="Top" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">
                    <Button Command="{Binding BackCommand}" CommandParameter="Dashboard" Style="{StaticResource SecondaryButtonStyle}" Width="150">
                        <TextBlock Text="Back" />
                    </Button>

                    <Button Command="{Binding AddCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="22,0,0,0" Width="150">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <fa:IconImage Icon="Check" Width="14" Height="14" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Save entry" Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
